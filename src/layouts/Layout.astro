---
import { SEO } from "astro-seo";
import Footer from "../components/footer.astro"; 
import Navbar from "../components/navbar/navbar.astro";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

// 1. TAMBAHKAN isHome di interface Props agar TypeScript tidak protes
export interface Props {
  title: string;
  isHome?: boolean; // Tanda tanya (?) berarti opsional
}

// 2. TANGKAP isHome dari Astro.props (Defaultnya false)
const { title, isHome = false } = Astro.props;

const siteUrl = Astro.site ? Astro.site.toString() : 'https://www.slbalfirmaunah.com';
const canonicalURL = new URL(Astro.url.pathname, siteUrl).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg",
  siteUrl
).toString();

// 3. MUTASI ABSOLUT: Mesin Pembuat Judul (SEO Title)
const makeTitle = title
  ? title + " | SLB Al-Firmaunah"
  : "SLB Al-Firmaunah | Mendidik dengan Hati";
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    
    <meta name="google-site-verification" content="NR7hPDeL5F8VFXdmMLb60FCccG3b6aPlzKNUnVsMty0" />
    
    <link rel="icon" type="image/png" href="/favicon.png" />
    
    <meta name="generator" content={Astro.generator} />
    
    <SEO
      title={makeTitle}
      description="Portal resmi SLB Al-Firmaunah. Lembaga pendidikan inklusif yang berdedikasi untuk memberikan layanan pembelajaran terbaik, membangun kemandirian, dan menggali potensi setiap peserta didik berkebutuhan khusus."
      canonical={canonicalURL}
      twitter={{
        creator: "@slbalfirmaunah",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: makeTitle,
          image: resolvedImageWithDomain,
        },
      }}
    />
  </head>
  <body>
    <Navbar isHome={isHome} />
    
    <slot />
    <Footer />
    <style is:global>
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>