---
import Layout from "../layouts/Layout.astro";
import Container from "../components/container.astro";
import { getEntry } from 'astro:content';

// 1. Ambil data dari Keystatic
const ppdbEntry = await getEntry('ppdb', 'info');

// 2. Setup data dengan fallback (agar tidak error jika data belum diisi)
const data = ppdbEntry?.data || {
  judulTahunAjaran: "Tahun Ajaran 2026/2027",
  posterTahunan: "https://images.unsplash.com/photo-1577896851231-70ef18881754?w=1080",
  whatsappNumber: "6281234567890",
  pesanWA: "Halo Admin SLB Al-Firmaunah, saya ingin menanyakan informasi pendaftaran siswa baru.",
  jadwalHari: "Senin - Jum'at",
  jadwalJam: "07.00 - 15.00",
  syarat: [],
  alur: [],
  brosurPdf: null
};

const whatsappUrl = `https://wa.me/${data.whatsappNumber}?text=${encodeURIComponent(data.pesanWA)}`;
---

<Layout title={`PPDB ${data.judulTahunAjaran} | SLB Al-Firmaunah`} isHome={false}>
  
  <header class="bg-red-950 text-white pt-44 pb-20 relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('/grid-pattern.svg')] opacity-10"></div>
    <Container>
      <div class="max-w-4xl relative z-10">
        <span class="text-red-600 font-black tracking-[0.3em] uppercase text-xs mb-6 inline-block bg-white px-6 py-2 rounded-full shadow-lg">
          Informasi Resmi
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black mb-4 tracking-tighter leading-tight text-white drop-shadow-sm">
          Penerimaan Peserta <br/> <span class="text-red-500">Didik Baru</span>
        </h1>
        <p class="text-lg text-red-100 font-medium max-w-xl">
          Bergabunglah bersama keluarga besar SLB Al-Firmaunah.
        </p>
      </div>
    </Container>
  </header>

  <section class="py-16 bg-slate-50 min-h-screen">
    <Container>
      
      <div class="flex flex-col md:flex-row items-start gap-10 lg:gap-16 max-w-7xl mx-auto">
        
        <div class="w-full md:w-5/12 lg:w-4/12 sticky top-44 z-20">
          <div class="bg-white p-2 rounded-[2rem] shadow-sm border border-slate-200/60 relative group">
            <div class="absolute -top-3 -right-3 bg-red-600 text-white font-black text-[10px] px-4 py-1.5 rounded-full uppercase tracking-widest shadow-lg z-20">
              Brosur {data.judulTahunAjaran}
            </div>
            
            <div class="aspect-[9/16] w-full bg-slate-100 rounded-[1.5rem] overflow-hidden relative border border-slate-100 shadow-inner">
              <img 
                src={data.posterTahunan} 
                alt={`Brosur PPDB ${data.judulTahunAjaran}`} 
                class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
              />
            </div>
          </div>
        </div>

        <div class="w-full md:w-7/12 lg:w-8/12 flex flex-col gap-12 pb-20">
          
          <div class="bg-white rounded-[2.5rem] p-8 md:p-10 shadow-sm border border-slate-100">
            <h2 class="text-2xl font-black text-slate-900 mb-8 uppercase tracking-tight flex items-center gap-4 border-b border-slate-100 pb-6">
              <span class="w-2 h-8 bg-red-600 rounded-full"></span>
              Persyaratan Administrasi
            </h2>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {data.syarat.length > 0 ? (
                data.syarat.map((item) => (
                  <div class="flex items-center gap-4 bg-slate-50 p-4 rounded-2xl border border-slate-200 hover:border-red-300 transition-all">
                    <div class="w-10 h-10 rounded-full bg-red-100 text-red-600 flex items-center justify-center shrink-0 font-black text-lg">
                      {item.catatan ? '?' : '✓'}
                    </div>
                    <div>
                      <p class="text-slate-700 font-bold text-sm leading-snug">{item.teks}</p>
                      {item.catatan && <p class="text-xs text-slate-500 font-medium mt-0.5">({item.catatan})</p>}
                    </div>
                  </div>
                ))
              ) : (
                <p class="text-slate-400 italic text-sm">Belum ada persyaratan yang ditambahkan.</p>
              )}
            </div>
          </div>

          <div class="bg-white rounded-[2.5rem] p-8 md:p-10 shadow-sm border border-slate-100 relative">
            <h2 class="text-2xl font-black text-slate-900 mb-10 uppercase tracking-tight flex items-center gap-4 border-b border-slate-100 pb-6">
              <span class="w-2 h-8 bg-red-600 rounded-full"></span>
              Alur Penerimaan
            </h2>
            
            <div class="relative pl-2 md:pl-4">
              <div class="absolute left-[26px] md:left-[34px] top-4 bottom-10 w-1 bg-red-100 rounded-full z-0"></div>
              <div class="space-y-10 relative z-10">
                {data.alur.length > 0 ? (
                  data.alur.map((step, index) => (
                    <div class="flex gap-6 md:gap-8 group items-start">
                      <div class="w-12 h-12 md:w-14 md:h-14 rounded-full bg-red-600 text-white flex items-center justify-center font-black text-xl shrink-0 group-hover:scale-110 transition-transform duration-300 shadow-lg relative z-10">
                        {index + 1}
                      </div>
                      <div class="pt-2">
                        <h3 class="text-xl font-black text-slate-900 mb-2 group-hover:text-red-600 transition-colors">
                          {step.judul}
                        </h3>
                        <p class="text-slate-500 leading-relaxed text-sm">{step.deskripsi}</p>
                      </div>
                    </div>
                  ))
                ) : (
                  <p class="text-slate-400 italic text-sm">Belum ada alur yang ditambahkan.</p>
                )}
              </div>
            </div>
          </div>

          <div class="bg-red-950 rounded-[2.5rem] p-8 md:p-10 text-white shadow-xl relative overflow-hidden border-t-8 border-red-600">
            <div class="absolute -right-20 -top-20 w-64 h-64 bg-red-600 rounded-full blur-3xl opacity-30 pointer-events-none"></div>

            <div class="relative z-10 flex flex-col xl:flex-row justify-between items-center gap-10">
              <div class="w-full xl:w-1/3 text-left">
                <span class="bg-red-600 text-white text-[10px] font-black px-4 py-1.5 rounded-full uppercase tracking-widest mb-4 inline-block shadow-md">
                  Pusat Layanan PPDB
                </span>
                <h3 class="text-3xl font-black mb-6 tracking-tight leading-tight">Siap Memulai <br/> Pendaftaran?</h3>
                
                <div class="bg-red-900/50 w-full xl:w-max px-5 py-4 rounded-2xl border border-red-800">
                   <div class="flex items-center gap-2 mb-3">
                     <div class="w-2.5 h-2.5 rounded-full bg-green-400 animate-pulse shadow-[0_0_8px_rgba(74,222,128,0.8)]"></div>
                     <span class="text-sm font-black uppercase tracking-widest text-white leading-none text-center">Buka</span>
                   </div>
                   <div class="space-y-1 text-sm">
                     <p class="text-red-100 flex items-center">
                        <span class="inline-block w-9 font-medium text-red-300">Hari</span>: <span class="font-bold text-white ml-1">{data.jadwalHari}</span>
                     </p>
                     <p class="text-red-100 flex items-center">
                        <span class="inline-block w-9 font-medium text-red-300">Jam</span>: <span class="font-bold text-white ml-1">{data.jadwalJam}</span>
                     </p>
                   </div>
                </div>
              </div>

              <div class="w-full xl:w-2/3 flex flex-col gap-4">
                <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-4 w-full bg-white text-red-600 py-6 px-10 rounded-3xl font-black uppercase tracking-widest hover:bg-slate-100 hover:scale-[1.02] transition-all shadow-xl shadow-black/10 group border border-slate-100">
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:rotate-12 transition-transform shrink-0">
                    <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-10.6 8.38 8.38 0 0 1 3.8.9L21 3z"></path>
                  </svg>
                  <span class="text-lg xl:text-xl text-center leading-none">Hubungi WhatsApp Admin</span>
                </a>

                {data.brosurPdf && (
                  <a 
                    href={data.brosurPdf} 
                    download 
                    class="flex items-center justify-center gap-3 w-full py-4 px-10 rounded-2xl font-bold uppercase tracking-[0.2em] text-[10px] text-red-300 border border-white/10 hover:bg-white/5 hover:text-white transition-all group"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-y-0.5 transition-transform">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                      <polyline points="7 10 12 15 17 10"></polyline>
                      <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                    Unduh Brosur Pendaftaran (PDF)
                  </a>
                )}
              </div>
            </div>
          </div>

        </div>
      </div>
    </Container>
  </section>
</Layout>