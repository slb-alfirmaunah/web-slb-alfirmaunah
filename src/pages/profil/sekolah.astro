---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/container.astro";
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';
import { DocumentRenderer } from '@keystatic/core/renderer';

const reader = createReader(process.cwd(), keystaticConfig);

let profil = null;
try {
  profil = await reader.singletons.profilSekolah.read();
} catch (error) {
  console.error("Gagal memuat profil sekolah:", error);
}

// Me-resolve konten sejarah dari document field
const sejarahKonten = profil?.sejarah ? await profil.sejarah() : null;
---

<Layout title="Identitas Sekolah | SLB Al-Firmaunah" isHome={false}>
  
  <div class="w-full py-24 bg-red-950 text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('/grid-pattern.svg')] opacity-10"></div>
    <Container>
      <div class="max-w-4xl mx-auto text-center relative z-10">
        <span class="text-red-500 font-black tracking-[0.3em] uppercase text-sm mb-4 block">
          Profil Lembaga
        </span>
        <h1 class="text-4xl md:text-6xl font-black tracking-tighter mb-8 leading-tight uppercase text-white">
          {profil?.judul || "Identitas Sekolah"}
        </h1>
        <p class="text-xl text-red-200 font-medium leading-relaxed max-w-2xl mx-auto italic">
          "{profil?.subjudul || "Mendidik dengan hati untuk kemandirian bangsa."}"
        </p>
      </div>
    </Container>
  </div>

  <section class="py-24 bg-white relative border-b border-slate-100">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        
        <div class="space-y-8">
          <div class="inline-flex items-center gap-4">
            <div class="w-12 h-1.5 bg-red-600 rounded-full"></div>
            <h2 class="text-3xl font-black text-slate-900 uppercase tracking-tight">Visi Kami</h2>
          </div>
          <div class="p-10 bg-slate-50 rounded-[3rem] border-l-[12px] border-red-600 shadow-xl shadow-slate-200/50">
            <p class="text-2xl md:text-3xl text-slate-700 font-bold leading-snug italic">
              "{profil?.visi || "Visi belum diatur."}"
            </p>
          </div>
        </div>

        <div class="space-y-8">
          <div class="inline-flex items-center gap-4">
            <div class="w-12 h-1.5 bg-red-600 rounded-full"></div>
            <h2 class="text-3xl font-black text-slate-900 uppercase tracking-tight">Misi Strategis</h2>
          </div>
          
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {profil?.misi?.map((item, index) => (
              <li class="flex gap-3 p-4 bg-white border border-slate-100 rounded-2xl hover:border-red-200 hover:shadow-md transition-all group items-start">
                <span class="flex-shrink-0 w-7 h-7 rounded-full bg-red-600 text-white flex items-center justify-center font-black text-[10px]">
                  {index + 1}
                </span>
                <p class="text-slate-600 font-bold leading-snug text-[12px] pt-1 uppercase tracking-tight">
                  {item.teks}
                </p>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </Container>
  </section>

  {sejarahKonten && (
    <section class="py-24 bg-slate-50 relative">
      <Container>
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-4xl font-black text-slate-900 mb-4 tracking-tight uppercase">Sejarah Sekolah</h2>
            <div class="w-24 h-2 bg-red-600 mx-auto rounded-full"></div>
          </div>
          
          <div class="bg-white p-8 md:p-16 rounded-[3rem] shadow-2xl shadow-slate-200/50 border border-slate-100">
            <article class="prose prose-slate prose-sm md:prose-base max-w-none 
              prose-p:text-slate-600 prose-p:leading-relaxed prose-p:mb-6
              prose-headings:text-slate-900 prose-headings:font-black prose-headings:uppercase prose-headings:tracking-tight
              prose-strong:text-red-600 prose-strong:font-black">
              
              <DocumentRenderer document={sejarahKonten} />
              
            </article>
          </div>
        </div>
      </Container>
    </section>
  )}

</Layout>