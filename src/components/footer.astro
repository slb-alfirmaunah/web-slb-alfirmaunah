---
// footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="bg-red-950 text-slate-300 pt-20 pb-10 font-sans border-t border-red-900">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      <div class="space-y-6">
        <div class="flex items-center gap-3">
          <img src="/logo-putih.png" alt="Logo SLB Al-Firmaunah" class="h-14 w-auto object-contain" onerror="this.style.display='none'" />
          <div class="flex flex-col">
            <span class="text-white font-black text-xl uppercase tracking-tighter leading-none">SLB Al-Firmaunah</span>
            <span class="text-[10px] uppercase tracking-[0.3em] font-bold text-red-400">Mendidik dengan Hati</span>
          </div>
        </div>
        <p class="text-sm leading-relaxed opacity-80">
          Lembaga pendidikan yang berdedikasi untuk memberikan layanan pembelajaran terbaik, membangun kemandirian, dan menggali potensi setiap peserta didik berkebutuhan khusus.
        </p>
        <div class="flex gap-4">
          <a href="#" class="w-10 h-10 rounded-full bg-red-900/50 flex items-center justify-center hover:bg-red-600 hover:text-white transition-all duration-300 border border-red-800">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-red-900/50 flex items-center justify-center hover:bg-red-600 hover:text-white transition-all duration-300 border border-red-800">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-red-900/50 flex items-center justify-center hover:bg-red-600 hover:text-white transition-all duration-300 border border-red-800">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
          </a>
        </div>
      </div>

      <div>
        <h4 class="text-white font-bold mb-8 uppercase tracking-widest text-sm">Navigasi</h4>
        <ul class="space-y-4 text-sm font-medium">
          <li><a href="/profil/sekolah" class="hover:text-red-400 transition-colors">Profil Sekolah</a></li>
          <li><a href="/berita" class="hover:text-red-400 transition-colors">Berita & Pengumuman</a></li>
          <li><a href="/fasilitas" class="hover:text-red-400 transition-colors">Fasilitas Kampus</a></li>
          <li><a href="/galeri" class="hover:text-red-400 transition-colors">Galeri Kegiatan</a></li>
          <li><a href="/ppdb" class="text-red-400 font-bold hover:underline">Informasi PPDB</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-bold mb-8 uppercase tracking-widest text-sm">Hubungi Kami</h4>
        <ul class="space-y-4 text-sm">
          <li class="flex gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-red-500 shrink-0"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            <span>Jl. Contoh Alamat No. 123, Kabupaten Malang, Jawa Timur</span>
          </li>
          <li class="flex gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-red-500 shrink-0"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.27-2.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            <span>(0341) 123456</span>
          </li>
          <li class="flex gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-red-500 shrink-0"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            <span>info@slbalfirmaunah.sch.id</span>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-bold mb-8 uppercase tracking-widest text-sm">Lokasi Sekolah</h4>
        <div class="rounded-xl overflow-hidden grayscale hover:grayscale-0 transition-all duration-500 border border-red-800">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d22354.582002673465!2d112.7527655062782!3d-7.919141782440526!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2dd62f000f9db923%3A0x17ef810fdbc8533!2sSLB%20AL-FIR%20MA&#39;UNAH!5e0!3m2!1sen!2sid!4v1774176983801!5m2!1sen!2sid" 
            width="100%" height="150" style="border:0;" allowfullscreen="" loading="lazy">
          </iframe>
        </div>
      </div>

    </div>

    <div class="pt-8 border-t border-red-900 flex flex-col md:flex-row justify-between items-center gap-4 text-xs font-bold uppercase tracking-widest opacity-60">
      <p>© {currentYear} SLB AL-FIRMA'UNAH. ALL RIGHTS RESERVED.</p>
      <div class="flex gap-6">
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>