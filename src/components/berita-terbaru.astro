---
import { getCollection } from 'astro:content';
const posts = await getCollection('berita');
const daftarBerita = posts
  .sort((a, b) => new Date(b.data.tanggal).getTime() - new Date(a.data.tanggal).getTime())
  .slice(0, 3);
---
<div class="w-full">
  <div class="flex justify-between items-end mb-10">
    <div>
      <span class="text-red-600 font-bold tracking-widest uppercase text-sm italic">Informasi Terkini</span>
      <h2 class="text-3xl md:text-4xl font-black text-slate-900 mt-2 tracking-tight">Berita & Pengumuman</h2>
    </div>
    <a href="/berita" class="hidden md:inline-flex items-center gap-2 text-red-600 font-bold hover:text-red-800 transition-colors uppercase text-xs tracking-widest">
      Lihat Semua <span>&rarr;</span>
    </a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {daftarBerita.length > 0 ? (
      daftarBerita.map((item) => (
        <article class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-xl transition-all group flex flex-col h-full hover:-translate-y-1 duration-300">
          <div class="relative h-52 w-full overflow-hidden bg-slate-200">
            <img src={item.data.gambar} alt={item.data.judul} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" onerror="this.src='https://images.unsplash.com/photo-1546410531-bb4caa6b424d?w=800'"/>
            <div class="absolute top-4 left-4">
              <span class="bg-red-600 text-white text-[10px] font-black px-3 py-1 rounded-lg uppercase tracking-wider shadow-lg">{item.data.kategori}</span>
            </div>
          </div>
          <div class="p-6 flex flex-col flex-grow text-left">
            <p class="text-slate-400 text-[10px] mb-2 font-black uppercase tracking-widest">
              {new Date(item.data.tanggal).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' })}
            </p>
            <h3 class="text-xl font-bold text-slate-900 mb-3 leading-tight group-hover:text-red-600 transition-colors line-clamp-2">{item.data.judul}</h3>
            <p class="text-slate-600 text-sm mb-6 line-clamp-3 leading-relaxed">{item.data.deskripsi}</p>
            <div class="mt-auto">
              <a href={`/berita/${item.id}`} class="text-red-600 text-xs font-black uppercase tracking-widest inline-flex items-center gap-1 group-hover:gap-2 transition-all">
                Baca Selengkapnya <span class="text-lg">→</span>
              </a>
            </div>
          </div>
        </article>
      ))
    ) : (
      <div class="col-span-full py-20 text-center bg-slate-100/50 rounded-3xl border-2 border-dashed border-slate-200 text-slate-400 italic">Belum ada berita.</div>
    )}
  </div>
</div>